{
  "version": 4,
  "configurations": [
    {
      "name": "Linux",
      "intelliSenseMode": "linux-gcc-x64",
      "cStandard": "c17",
      "compileCommands": "${workspaceFolder}/compile_commands.json",
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/include",
        "/usr/include/SDL2",
        "/usr/include/freetype2",
        "/usr/include/libpng16"
      ],
      "defines": [
        "_GNU_SOURCE=1",
        "_REENTRANT"
      ]
    }
  ]
}